# Linear credentials
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# Optional Linear routing
LINEAR_PROJECT_NAME=Competitions
LINEAR_PROJECT_ID=
LINEAR_BACKLOG_STATE_NAME=Backlog
LINEAR_BACKLOG_STATE_ID=

# Comma- or space-separated sources to run: ctf, codeforces, atcoder, clist_dmoj, dmoj, or all.
# This is required; the runner has no fallback default.
CONTEST_REMINDER_SCRIPTS=ctf,codeforces,atcoder

# Set to 1 to preview Linear creates/updates without writing them.
CONTEST_REMINDER_DRY_RUN=0
